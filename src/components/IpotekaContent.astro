<!-- ── FAQ ── -->
<section class="content-section reveal">
  <h2>Частые вопросы</h2>

  <div class="faq-item">
    <button class="faq-question" aria-expanded="false">
      Какая ставка по ипотеке сейчас?
      <span class="faq-chevron">&#9660;</span>
