---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PercentageCalculator from '../components/PercentageCalculator.tsx';
import PercentageCalculatorContent from '../components/PercentageCalculatorContent.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate the percentage of a number?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply the number by the percentage and divide by 100. For example, 15% of 200 = 200 × 15 / 100 = 30. Or equivalently, multiply by the decimal: 200 × 0.15 = 30."
      }
    },
    {
      "@type": "Question",
      "name": "How do I find what percentage one number is of another?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide the part by the whole and multiply by 100. For example, 30 is what percent of 200? Answer: (30 / 200) × 100 = 15%. Use the 'X is what %' tab for this."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate percentage increase or decrease?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Percentage change = (New Value - Old Value) / Old Value × 100. From 80 to 100: (100-80)/80 × 100 = 25% increase. From 100 to 80: (80-100)/100 × 100 = -20% decrease."
      }
    },
    {
      "@type": "Question",
      "name": "Can percentage change be negative?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A negative percentage change means a decrease. Going from 100 to 80 is a -20% change. The calculator shows this as a decrease with the exact percentage."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between percentage and percentage points?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If an interest rate goes from 5% to 7%, that's a 2 percentage point increase but a 40% relative increase ((7-5)/5 × 100). Percentage points measure the absolute difference between two percentages. This calculator computes the relative percentage change."
      }
    }
  ]
};
---
<BaseLayout
  title="Percentage Calculator — sum.money"
  description="Calculate percentages three ways: X% of Y, what percent X is of Y, or percentage change between two numbers. Free, instant results."
  schema={schema}
>
  <Header activeMarket="" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span>Percentage Calculator
  </div>
  <main>
    <h1 class="animate-in delay-1">Percentage Calculator</h1>
    <p class="subtitle animate-in delay-2">Three ways to calculate percentages — pick the tab that matches your question.</p>
    <PercentageCalculator client:load />
    <PercentageCalculatorContent />
  </main>
</BaseLayout>
