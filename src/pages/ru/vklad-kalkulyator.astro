---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import VkladCalculator from '../../components/VkladCalculator.tsx';
import VkladContent from '../../components/VkladContent.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Как рассчитать доход по вкладу?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Доход зависит от суммы, ставки, срока и капитализации. Без капитализации: доход = сумма × ставка × срок/12. С ежемесячной капитализацией процентов доход выше за счёт начисления процентов на проценты. Пример: 1 000 000 ₽ под 21% на 12 месяцев = ~210 000 ₽ без капитализации."
      }
    },
    {
      "@type": "Question",
      "name": "Какой налог на проценты по вкладам?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "С 2024 года налог НДФЛ 13% взимается с процентного дохода, превышающего необлагаемый лимит. Лимит = 1 000 000 ₽ × максимальная ключевая ставка ЦБ на 1-е число каждого месяца года. В 2025 году при ставке 21% лимит составляет ~210 000 ₽."
      }
    },
    {
      "@type": "Question",
      "name": "Что такое капитализация процентов?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Капитализация — это начисление процентов на ранее начисленные проценты. При ежемесячной капитализации проценты каждый месяц прибавляются к сумме вклада, и в следующем месяце проценты начисляются на увеличенную сумму. Это увеличивает итоговый доход."
      }
    },
    {
      "@type": "Question",
      "name": "Какая средняя ставка по вкладам в 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Средняя ставка по вкладам в крупнейших банках России в 2025 году составляет 20–22% годовых. Ставки зависят от ключевой ставки ЦБ РФ (21% на начало 2025). Максимальные ставки — по вкладам на 6–12 месяцев без снятия."
      }
    }
  ]
};
---
<BaseLayout
  title="Калькулятор вклада — Рассчитать доход по депозиту — sum.money"
  description="Рассчитайте доходность вклада с капитализацией, пополнением и налогом. Сравните два вклада. Бесплатно, мгновенно."
  schema={schema}
>
  <Header activeMarket="RU" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span><a href="/ru">Россия</a><span>›</span>Калькулятор вклада
  </div>
  <main>
    <h1 class="animate-in delay-1">Калькулятор вклада</h1>
    <p class="subtitle animate-in delay-2">Рассчитайте доход по депозиту с учётом капитализации и налога. Или сравните два вклада.</p>
    <VkladCalculator client:load />
    <VkladContent />
  </main>
</BaseLayout>
