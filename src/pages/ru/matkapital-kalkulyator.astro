---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import MatkapitalCalculator from '../../components/MatkapitalCalculator.tsx';
import MatkapitalContent from '../../components/MatkapitalContent.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Какой размер маткапитала в 2025 году?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "На первого ребёнка (рождённого с 2020 года) — 690 266 ₽. На второго, если не получали на первого — 912 162 ₽. Доплата на второго, если получали на первого — 221 895 ₽. Суммы индексируются ежегодно."
      }
    },
    {
      "@type": "Question",
      "name": "На что можно потратить маткапитал?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Основные направления: улучшение жилищных условий (ипотека, покупка, строительство), образование детей (до 25 лет), накопительная пенсия матери, адаптация детей-инвалидов, ежемесячная выплата на второго ребёнка (при низком доходе)."
      }
    },
    {
      "@type": "Question",
      "name": "Когда можно использовать маткапитал?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "На ипотеку и первоначальный взнос — сразу после получения сертификата. На покупку жилья без ипотеки, образование и другие цели — после 3-летия ребёнка. На ежемесячную выплату — сразу, но только при доходе семьи ниже двух прожиточных минимумов."
      }
    },
    {
      "@type": "Question",
      "name": "Можно ли обналичить маткапитал?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Нет, обналичивание маткапитала незаконно и наказуемо. Единственный способ получить деньги — ежемесячная выплата на второго ребёнка до 3 лет (при низком доходе семьи). Все остальные способы — целевые: деньги переводятся напрямую продавцу, банку или образовательному учреждению."
      }
    }
  ]
};
---
<BaseLayout
  title="Калькулятор маткапитала 2025 — Размер и условия — sum.money"
  description="Рассчитайте размер материнского капитала на 2025 год. На первого, второго ребёнка. Условия использования на ипотеку, образование, пенсию."
  schema={schema}
>
  <Header activeMarket="RU" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span><a href="/ru">Россия</a><span>›</span>Калькулятор маткапитала
  </div>
  <main>
    <h1 class="animate-in delay-1">Калькулятор маткапитала 2025</h1>
    <p class="subtitle animate-in delay-2">Узнайте размер материнского капитала и условия использования.</p>
    <MatkapitalCalculator client:load />
    <MatkapitalContent />
  </main>
</BaseLayout>
