---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import KreditCalculator from '../../components/KreditCalculator.tsx';
import KreditContent from '../../components/KreditContent.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Как рассчитать ежемесячный платёж по кредиту?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Аннуитетный платёж: M = P × [r(1+r)^n] / [(1+r)^n − 1]. При кредите 500 000 ₽ под 24% на 36 месяцев ежемесячный платёж составит ~19 700 ₽. Общая переплата — около 210 000 ₽."
      }
    },
    {
      "@type": "Question",
      "name": "Аннуитетный или дифференцированный — что выгоднее?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Дифференцированный платёж выгоднее по общей переплате, но первые платежи значительно выше. Аннуитетный — равные платежи на весь срок, удобнее для бюджета. Большинство банков в России выдают кредиты с аннуитетным платежом."
      }
    },
    {
      "@type": "Question",
      "name": "Какая средняя ставка по потребительским кредитам?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Средняя ставка по потребительским кредитам в 2025 году составляет 22–28% годовых. Ставка зависит от банка, кредитной истории, суммы и срока. Кредиты с обеспечением (залогом) обычно дешевле."
      }
    },
    {
      "@type": "Question",
      "name": "Как уменьшить переплату по кредиту?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "1. Берите кредит на минимально возможный срок — это главный фактор переплаты. 2. Делайте досрочные погашения — особенно в первые месяцы. 3. Выбирайте дифференцированный платёж, если можете позволить высокие первые платежи. 4. Сравнивайте предложения нескольких банков."
      }
    }
  ]
};
---
<BaseLayout
  title="Кредитный калькулятор — Рассчитать платёж по кредиту — sum.money"
  description="Рассчитайте ежемесячный платёж, переплату и общую сумму выплат по потребительскому кредиту. Аннуитетный и дифференцированный платёж."
  schema={schema}
>
  <Header activeMarket="RU" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span><a href="/ru">Россия</a><span>›</span>Кредитный калькулятор
  </div>
  <main>
    <h1 class="animate-in delay-1">Кредитный калькулятор</h1>
    <p class="subtitle animate-in delay-2">Рассчитайте платёж, переплату и общую стоимость потребительского кредита.</p>
    <KreditCalculator client:load />
    <KreditContent />
  </main>
</BaseLayout>
