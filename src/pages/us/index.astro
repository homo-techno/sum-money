---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
---
<BaseLayout
  title="US Financial Calculators — sum.money"
  description="Free financial calculators for the United States. Mortgage, income tax, paycheck, 401(k), and more. No registration, no cookies."
>
  <Header activeMarket="US" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span>US
  </div>
  <main>
    <h1 class="animate-in delay-1">Financial Calculators for the United States</h1>
    <p class="subtitle animate-in delay-2">US-specific formulas, rates, and tax rules.</p>

    <section class="content-section animate-in delay-3">
      <div class="related-grid">
        <a href="/us/mortgage-calculator" class="related-card">
          <div class="related-card-title">🏠 Mortgage Calculator</div>
          <div class="related-card-desc">Enter your income — see the maximum home price you can afford.</div>
        </a>
        <a href="/us/income-tax-calculator" class="related-card">
          <div class="related-card-title">📋 Income Tax Calculator 2025</div>
          <div class="related-card-desc">See your take-home pay after federal tax. Employee and self-employed.</div>
        </a>
        <a href="/us/paycheck-calculator" class="related-card">
          <div class="related-card-title">💰 Paycheck Calculator</div>
          <div class="related-card-desc">See your take-home pay per paycheck — salary or hourly.</div>
        </a>
        <a href="/us/401k-calculator" class="related-card">
          <div class="related-card-title">📈 401(k) Calculator</div>
          <div class="related-card-desc">Project your 401(k) balance at retirement with employer match.</div>
        </a>
        <a href="/us/roth-ira-calculator" class="related-card">
          <div class="related-card-title">🏦 Roth IRA Calculator</div>
          <div class="related-card-desc">Project tax-free growth — or compare Roth vs Traditional.</div>
        </a>
        <a href="/us/tax-bracket-calculator" class="related-card">
          <div class="related-card-title">📊 Tax Bracket Calculator</div>
          <div class="related-card-desc">See which bracket you're in — with visual breakdown.</div>
        </a>
        <a href="/us/capital-gains-tax-calculator" class="related-card">
          <div class="related-card-title">💹 Capital Gains Tax Calculator</div>
          <div class="related-card-desc">Calculate tax on investment gains — long-term and short-term.</div>
        </a>
        <a href="/us/auto-loan-calculator" class="related-card">
          <div class="related-card-title">🚗 Auto Loan Calculator</div>
          <div class="related-card-desc">Monthly car payment, total interest, and total cost.</div>
        </a>
        <a href="/us/home-affordability-calculator" class="related-card">
          <div class="related-card-title">🏡 Home Affordability Calculator</div>
          <div class="related-card-desc">How much house can you afford? Based on income and DTI.</div>
        </a>
        <a href="/us/mortgage-refinance-calculator" class="related-card">
          <div class="related-card-title">🔄 Mortgage Refinance Calculator</div>
          <div class="related-card-desc">Should you refinance? See savings and break-even point.</div>
        </a>
        <a href="/us/down-payment-calculator" class="related-card">
          <div class="related-card-title">💵 Down Payment Calculator</div>
          <div class="related-card-desc">How much to put down — or how long to save.</div>
        </a>
        <a href="/us/debt-payoff-calculator" class="related-card">
          <div class="related-card-title">📉 Debt Payoff Calculator</div>
          <div class="related-card-desc">Snowball vs avalanche — find your debt-free date.</div>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
