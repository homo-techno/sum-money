---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import StampDutyCalculator from '../../components/StampDutyCalculator.tsx';
import StampDutyContent from '../../components/StampDutyContent.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much is Stamp Duty in 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "From 1 April 2025, SDLT rates for England and Northern Ireland are: 0% up to £125,000, 2% on £125,001–£250,000, 5% on £250,001–£925,000, 10% on £925,001–£1,500,000, and 12% above £1,500,000. First-time buyers pay 0% up to £300,000 and 5% on £300,001–£500,000 (if the property costs £500,000 or less)."
      }
    },
    {
      "@type": "Question",
      "name": "Do first-time buyers pay Stamp Duty?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "First-time buyers pay no Stamp Duty on properties up to £300,000. For properties between £300,001 and £500,000, they pay 5% only on the portion above £300,000. If the property costs more than £500,000, first-time buyer relief doesn't apply and standard rates are charged."
      }
    },
    {
      "@type": "Question",
      "name": "What is the additional property surcharge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you're buying an additional residential property (second home, buy-to-let, or holiday home), you pay a 5% surcharge on top of the standard SDLT rates on every band. This increased from 3% to 5% in October 2024."
      }
    },
    {
      "@type": "Question",
      "name": "Does Stamp Duty apply in Scotland and Wales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No — Scotland has its own Land and Buildings Transaction Tax (LBTT) and Wales has Land Transaction Tax (LTT). Both have different rates and thresholds. This calculator covers SDLT for England and Northern Ireland only."
      }
    }
  ]
};
---
<BaseLayout
  title="Stamp Duty Calculator 2025 — SDLT Rates — sum.money"
  description="Calculate Stamp Duty Land Tax for England and Northern Ireland. Updated for April 2025 rates. First-time buyer relief, additional property surcharge."
  schema={schema}
>
  <Header activeMarket="UK" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span><a href="/uk">UK</a><span>›</span>Stamp Duty Calculator
  </div>
  <main>
    <h1 class="animate-in delay-1">Stamp Duty Calculator 2025</h1>
    <p class="subtitle animate-in delay-2">Calculate SDLT on your property purchase — standard rates or first-time buyer relief.</p>
    <StampDutyCalculator client:load />
    <StampDutyContent />
  </main>
</BaseLayout>
