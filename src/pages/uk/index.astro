---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
---
<BaseLayout
  title="UK Financial Calculators — sum.money"
  description="Free financial calculators for the United Kingdom. Mortgage, income tax, stamp duty, pension, student loan, and more. No registration, no cookies."
>
  <Header activeMarket="UK" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span>UK
  </div>
  <main>
    <h1 class="animate-in delay-1">Financial Calculators for the United Kingdom</h1>
    <p class="subtitle animate-in delay-2">UK-specific formulas, HMRC rates, and tax rules for 2025/26.</p>

    <section class="content-section animate-in delay-3">
      <div class="related-grid">
        <a href="/uk/mortgage-calculator" class="related-card">
          <div class="related-card-title">🏠 Mortgage Calculator</div>
          <div class="related-card-desc">First-time buyer affordability, remortgage savings, or overpayment impact.</div>
        </a>
        <a href="/uk/stamp-duty-calculator" class="related-card">
          <div class="related-card-title">🏷️ Stamp Duty Calculator</div>
          <div class="related-card-desc">SDLT for England & Northern Ireland — standard and first-time buyer rates.</div>
        </a>
        <a href="/uk/income-tax-calculator" class="related-card">
          <div class="related-card-title">📋 Income Tax Calculator 2025/26</div>
          <div class="related-card-desc">Take-home pay after income tax and National Insurance. Employed or self-employed.</div>
        </a>
        <a href="/uk/take-home-pay-calculator" class="related-card">
          <div class="related-card-title">💰 Take-Home Pay Calculator</div>
          <div class="related-card-desc">Annual salary to monthly pay — or convert a contractor daily rate.</div>
        </a>
        <a href="/uk/pension-calculator" class="related-card">
          <div class="related-card-title">📈 Pension Calculator</div>
          <div class="related-card-desc">Project your workplace pension pot — or check your State Pension entitlement.</div>
        </a>
        <a href="/uk/student-loan-calculator" class="related-card">
          <div class="related-card-title">🎓 Student Loan Calculator</div>
          <div class="related-card-desc">Monthly repayment, years to repay, and how much gets written off.</div>
        </a>
        <a href="/uk/vat-calculator" class="related-card">
          <div class="related-card-title">🧾 VAT Calculator</div>
          <div class="related-card-desc">Add or remove VAT at 20%, 5%, or 0%.</div>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
