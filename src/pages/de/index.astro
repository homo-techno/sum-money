---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
---
<BaseLayout
  title="Finanzrechner für Deutschland — sum.money"
  description="Kostenlose Finanzrechner für Deutschland. Hypothekenrechner, Zinsrechner und mehr. Keine Registrierung, keine Cookies."
  lang="de"
>
  <Header activeMarket="DE" />
  <main>
    <h1 class="animate-in delay-1">Finanzrechner für Deutschland</h1>
    <p class="subtitle animate-in delay-2">Echte Formeln für den deutschen Markt. Keine Registrierung, keine Cookies.</p>

    <section class="content-section animate-in delay-3">
      <div class="related-grid">
        <a href="/de/hypothekenrechner" class="related-card">
          <div class="related-card-title">🏠 Hypothekenrechner</div>
          <div class="related-card-desc">Maximalen Kaufpreis berechnen, Anschlussfinanzierung vergleichen, Sondertilgung planen.</div>
        </a>
        <a href="/de/einkommensteuerrechner" class="related-card">
          <div class="related-card-title">📋 Einkommensteuerrechner 2026</div>
          <div class="related-card-desc">Nettoeinkommen berechnen — als Arbeitnehmer oder Selbstständiger.</div>
        </a>
        <a href="/de/gehaltsrechner" class="related-card">
          <div class="related-card-title">💰 Gehaltsrechner</div>
          <div class="related-card-desc">Monatsbrutto in Netto umrechnen — oder Wunsch-Netto in Brutto.</div>
        </a>
        <a href="/de/kreditrechner" class="related-card">
          <div class="related-card-title">💳 Kreditrechner</div>
          <div class="related-card-desc">Monatliche Rate und Gesamtkosten für jeden Ratenkredit.</div>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
