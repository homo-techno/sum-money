---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import EinkommensteuerrechnerCalculator from '../../components/EinkommensteuerrechnerCalculator.tsx';
import EinkommensteuerrechnerContent from '../../components/EinkommensteuerrechnerContent.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen Grenzsteuersatz und effektivem Steuersatz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der Grenzsteuersatz ist der Steuersatz auf den letzten verdienten Euro. Der effektive Steuersatz ist die tatsächlich gezahlte Steuer als Prozentsatz des Gesamteinkommens. Bei €55.000 Brutto liegt der Grenzsteuersatz bei 22%, der effektive Steuersatz aber nur bei ca. 15,6% — weil die ersten €12.348 steuerfrei sind und niedrigere Zonen weniger besteuert werden."
      }
    },
    {
      "@type": "Question",
      "name": "Muss ich Solidaritätszuschlag zahlen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Seit 2021 zahlen ca. 90% der Steuerzahler keinen Soli mehr. Die Freigrenze liegt 2026 bei €20.350 Einkommensteuer (Einzelveranlagte) — das entspricht einem Bruttoeinkommen von ca. €125.000 (Steuerklasse I). Erst darüber wird der Soli von 5,5% fällig, mit einer Milderungszone für Einkommen knapp darüber."
      }
    },
    {
      "@type": "Question",
      "name": "Wie wirkt sich die Steuerklasse auf mein Netto aus?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Steuerklasse bestimmt vor allem die monatliche Lohnsteuer. Steuerklasse III (verheiratet, Alleinverdiener) führt zu deutlich weniger Abzügen als Klasse I oder V. Wichtig: Die jährliche Einkommensteuer gleicht sich bei der Steuererklärung aus — die Steuerklasse beeinflusst nur die unterjährige Verteilung."
      }
    },
    {
      "@type": "Question",
      "name": "Sind Sozialabgaben Steuern?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. Sozialabgaben (KV, PV, RV, AV) sind Versicherungsbeiträge, keine Steuern. Sie finanzieren Krankenversicherung, Pflege, Rente und Arbeitslosenschutz. Arbeitgeber und Arbeitnehmer teilen die Beiträge jeweils zur Hälfte. Bei einem Brutto von €55.000 betragen die SV-Abgaben des Arbeitnehmers ca. €11.200/Jahr."
      }
    },
    {
      "@type": "Question",
      "name": "Wie viel sollte ich als Selbstständiger für Steuern zurücklegen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Als Faustregel: 30-40% des Gewinns für Einkommensteuer, Soli und Krankenversicherung. Der Rechner zeigt die genaue Aufschlüsselung. Wichtig: Das Finanzamt verlangt vierteljährliche Vorauszahlungen — planen Sie diese von Anfang an ein."
      }
    }
  ]
};

const alternates = [
  { hreflang: 'de-de', href: 'https://sum.money/de/einkommensteuerrechner' },
  { hreflang: 'en-us', href: 'https://sum.money/us/income-tax-calculator' },
];
---
<BaseLayout
  title="Einkommensteuerrechner 2026 — sum.money"
  description="Einkommensteuer 2026 berechnen: Nettoeinkommen für Arbeitnehmer und Selbstständige. Mit Sozialabgaben, Soli, Kirchensteuer. Kostenlos, sofort, teilbar."
  schema={schema}
  lang="de"
  alternates={alternates}
>
  <Header activeMarket="DE" />
  <div class="breadcrumbs animate-in">
    <a href="/">Home</a><span>›</span><a href="/de">DE</a><span>›</span>Einkommensteuerrechner
  </div>
  <main>
    <h1 class="animate-in delay-1">Einkommensteuerrechner 2026</h1>
    <p class="subtitle animate-in delay-2">Berechnen Sie Ihr Nettoeinkommen — als Arbeitnehmer oder Selbstständiger.</p>
    <EinkommensteuerrechnerCalculator client:load />
    <EinkommensteuerrechnerContent />
  </main>
</BaseLayout>
