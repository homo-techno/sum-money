---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---
<BaseLayout
  title="sum.money — Free Financial Calculators"
  description="Free financial calculators for 50+ countries. Mortgage, tax, compound interest, and more. No registration, no cookies."
>
  <Header />
  <main>
    <h1 class="animate-in delay-1">Free Financial Calculators</h1>
    <p class="subtitle animate-in delay-2">Real formulas for real markets. No registration, no cookies.</p>

    <section class="content-section animate-in delay-3">
      <h2>Universal</h2>
      <div class="related-grid">
        <a href="/compound-interest-calculator" class="related-card">
          <div class="related-card-title">📈 Compound Interest Calculator</div>
          <div class="related-card-desc">See how your savings grow — or find out how much to save for a goal.</div>
        </a>
        <a href="/salary-to-hourly-converter" class="related-card">
          <div class="related-card-title">🕐 Salary to Hourly Calculator</div>
          <div class="related-card-desc">Convert annual salary to hourly rate — or compare two job offers.</div>
        </a>
        <a href="/loan-calculator" class="related-card">
          <div class="related-card-title">💰 Loan Calculator</div>
          <div class="related-card-desc">Monthly payment, total interest, and payoff date for any loan.</div>
        </a>
        <a href="/percentage-calculator" class="related-card">
          <div class="related-card-title">🔢 Percentage Calculator</div>
          <div class="related-card-desc">Calculate X% of Y, find what percent X is of Y, or percentage change.</div>
        </a>
        <a href="/discount-calculator" class="related-card">
          <div class="related-card-title">🏷️ Discount Calculator</div>
          <div class="related-card-desc">Final price after one or two stacked discounts.</div>
        </a>
        <a href="/margin-calculator" class="related-card">
          <div class="related-card-title">📊 Profit Margin Calculator</div>
          <div class="related-card-desc">Calculate margin from revenue — or find the price from markup.</div>
        </a>
        <a href="/tip-calculator" class="related-card">
          <div class="related-card-title">🍽️ Tip Calculator</div>
          <div class="related-card-desc">Calculate tip and split the bill evenly.</div>
        </a>
      </div>
    </section>

    <section class="content-section animate-in delay-3">
      <h2>United States</h2>
      <div class="related-grid">
        <a href="/us/mortgage-calculator" class="related-card">
          <div class="related-card-title">🏠 Mortgage Calculator</div>
          <div class="related-card-desc">Enter your income — see the maximum home price you can afford.</div>
        </a>
        <a href="/us/income-tax-calculator" class="related-card">
          <div class="related-card-title">📋 Income Tax Calculator 2025</div>
          <div class="related-card-desc">See your take-home pay after federal tax. Employee and self-employed.</div>
        </a>
        <a href="/us/paycheck-calculator" class="related-card">
          <div class="related-card-title">💰 Paycheck Calculator</div>
          <div class="related-card-desc">See your take-home pay per paycheck — salary or hourly.</div>
        </a>
        <a href="/us/401k-calculator" class="related-card">
          <div class="related-card-title">📈 401(k) Calculator</div>
          <div class="related-card-desc">Project your 401(k) balance at retirement with employer match.</div>
        </a>
        <a href="/us/roth-ira-calculator" class="related-card">
          <div class="related-card-title">🏦 Roth IRA Calculator</div>
          <div class="related-card-desc">Project tax-free growth — or compare Roth vs Traditional.</div>
        </a>
        <a href="/us/tax-bracket-calculator" class="related-card">
          <div class="related-card-title">📊 Tax Bracket Calculator</div>
          <div class="related-card-desc">See which bracket you're in — with visual breakdown.</div>
        </a>
        <a href="/us/capital-gains-tax-calculator" class="related-card">
          <div class="related-card-title">💹 Capital Gains Tax Calculator</div>
          <div class="related-card-desc">Calculate tax on investment gains — long-term and short-term.</div>
        </a>
        <a href="/us/auto-loan-calculator" class="related-card">
          <div class="related-card-title">🚗 Auto Loan Calculator</div>
          <div class="related-card-desc">Monthly car payment, total interest, and total cost.</div>
        </a>
        <a href="/us/home-affordability-calculator" class="related-card">
          <div class="related-card-title">🏡 Home Affordability Calculator</div>
          <div class="related-card-desc">How much house can you afford? Based on income and DTI.</div>
        </a>
        <a href="/us/mortgage-refinance-calculator" class="related-card">
          <div class="related-card-title">🔄 Mortgage Refinance Calculator</div>
          <div class="related-card-desc">Should you refinance? See savings and break-even point.</div>
        </a>
        <a href="/us/down-payment-calculator" class="related-card">
          <div class="related-card-title">💵 Down Payment Calculator</div>
          <div class="related-card-desc">How much to put down — or how long to save.</div>
        </a>
        <a href="/us/debt-payoff-calculator" class="related-card">
          <div class="related-card-title">📉 Debt Payoff Calculator</div>
          <div class="related-card-desc">Snowball vs avalanche — find your debt-free date.</div>
        </a>
      </div>
    </section>

    <section class="content-section animate-in delay-3">
      <h2>Deutschland</h2>
      <div class="related-grid">
        <a href="/de/hypothekenrechner" class="related-card">
          <div class="related-card-title">🏠 Hypothekenrechner</div>
          <div class="related-card-desc">Maximalen Kaufpreis berechnen, Anschlussfinanzierung vergleichen, Sondertilgung planen.</div>
        </a>
        <a href="/de/einkommensteuerrechner" class="related-card">
          <div class="related-card-title">📋 Einkommensteuerrechner 2025</div>
          <div class="related-card-desc">Nettoeinkommen berechnen — als Arbeitnehmer oder Selbstständiger.</div>
        </a>
        <a href="/de/gehaltsrechner" class="related-card">
          <div class="related-card-title">💰 Gehaltsrechner</div>
          <div class="related-card-desc">Monatsbrutto in Netto umrechnen — oder Wunsch-Netto in Brutto.</div>
        </a>
        <a href="/de/kreditrechner" class="related-card">
          <div class="related-card-title">💳 Kreditrechner</div>
          <div class="related-card-desc">Monatliche Rate und Gesamtkosten für jeden Ratenkredit.</div>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
