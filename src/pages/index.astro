---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---
<BaseLayout
  title="sum.money — Free Financial Calculators"
  description="Free financial calculators for 50+ countries. Mortgage, tax, compound interest, and more. No registration, no cookies."
>
  <Header />
  <main>
    <h1 class="animate-in delay-1">Free Financial Calculators</h1>
    <p class="subtitle animate-in delay-2">Real formulas for real markets. No registration, no cookies.</p>

    <section class="content-section animate-in delay-3">
      <h2>Universal</h2>
      <div class="related-grid">
        <a href="/compound-interest" class="related-card">
          <div class="related-card-title">📈 Compound Interest Calculator</div>
          <div class="related-card-desc">See how your savings grow — or find out how much to save for a goal.</div>
        </a>
        <a href="/salary-to-hourly" class="related-card">
          <div class="related-card-title">🕐 Salary to Hourly Calculator</div>
          <div class="related-card-desc">Convert annual salary to hourly rate — or compare two job offers.</div>
        </a>
        <a href="/loan-calculator" class="related-card">
          <div class="related-card-title">💰 Loan Calculator</div>
          <div class="related-card-desc">Monthly payment, total interest, and payoff date for any loan.</div>
        </a>
      </div>
    </section>

    <section class="content-section animate-in delay-3">
      <h2>United States</h2>
      <div class="related-grid">
        <a href="/us/mortgage" class="related-card">
          <div class="related-card-title">🏠 Mortgage Calculator</div>
          <div class="related-card-desc">Enter your income — see the maximum home price you can afford.</div>
        </a>
      </div>
      <p style="margin-top: 24px; color: var(--ink-muted); font-size: .88rem;">More calculators coming soon.</p>
    </section>
  </main>
</BaseLayout>
